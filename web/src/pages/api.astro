---
// Redirect /api to the FastAPI interactive docs.
// Uses PUBLIC_API_BASE so it works in dev (localhost:8000) and production.
const apiBase: string =
    import.meta.env.PUBLIC_API_BASE ?? "http://localhost:8000/api/v1";
const docsUrl = apiBase.replace(/\/api\/v1\/?$/, "") + "/docs";

return Astro.redirect(docsUrl, 302);
---
